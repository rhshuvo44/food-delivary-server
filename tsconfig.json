{
  "compilerOptions": {
    "target": "ES2022",

    "module": "node16",
    "moduleResolution": "node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "resolveJsonModule": true,

    "types": ["node"],

    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}