# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/food_delivery

# PostgreSQL Configuration (for Docker)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=food_delivery
DB_PORT=5432

# PgAdmin Configuration (for Docker)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production_min_32_characters
ACCESS_TOKEN_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your_session_secret_key_here_change_in_production_min_32_characters

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
